# VLM provider 설정
VLM_PROVIDER=mock            # mock | openai | google | gpustack | vllm(예약)
VLM_MODEL=gpt-4o
VLM_API_KEY=

# 셀프호스트/OpenAI 호환 provider(gpustack) base URL — 경로 없이(예: http://host:8080).
# GPUStack 은 /v1-openai/ 를 자동으로 붙인다. openai/google 은 비워둔다.
VLM_ENDPOINT=

# 전용 ML 분류기(신뢰성 플라이휠 ②~③ 2중체크) — VLM 과 직교한 교차검증 판정원.
# none(기본) = ML 없음(VLM 단독, ② 이전과 동일). mock = 키 없는 데모(불일치→검토 큐 구동).
# mloop = 학습 모델 serve(ML_ENDPOINT 필요, FW-4 실통합 게이트).
ML_PROVIDER=none             # none | mock | mloop
ML_ENDPOINT=                 # mloop serve base URL(예: http://host:5000) — mloop 전용
ML_MODEL=default             # mloop promote 모델 이름
ML_TOKEN=                    # mloop serve JWT Bearer(비면 헤더 미부착)
# 2중체크 검토 임계: VLM 또는 ML 신뢰도 < 값이면 requires_review. 0(기본)=불일치만 검토.
ML_REVIEW_CONFIDENCE_THRESHOLD=0

# 업로드 제한 (DoS 방지)
MAX_UPLOAD_SIZE_MB=10
