# VLM provider 설정
VLM_PROVIDER=mock            # mock | openai | google | gpustack | vllm(예약)
VLM_MODEL=gpt-4o
VLM_API_KEY=

# 셀프호스트/OpenAI 호환 provider(gpustack) base URL — 경로 없이(예: http://host:8080).
# GPUStack 은 /v1-openai/ 를 자동으로 붙인다. openai/google 은 비워둔다.
VLM_ENDPOINT=

# 업로드 제한 (DoS 방지)
MAX_UPLOAD_SIZE_MB=10
