<?xml version="1.0" encoding="utf-8"?>
<!--
  소비 프로젝트는 오직 NuGet.org 의 게시된 패키지만 복원한다(글로벌 정책).
  머신 전역에 등록된 로컬 소스(D:\local-nuget-packages 등)는 divergent pack 으로
  캐시를 오염시키고 CI 에서는 존재하지도 않는다. <clear/> 로 상속 소스를 끊어
  복원을 결정론적·CI 안전하게 만든다.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
